# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# IMPORTANT: rotate this DB password. It was shared in plain text.

DB_NAME=turfbooking
DB_HOST=shoutt2002-chatapp2002.g.aivencloud.com
DB_PORT=22893
DB_USER=avnadmin
DB_PASSWORD=__PUT_YOUR_ROTATED_PASSWORD_HERE__

# Aiven MySQL requires TLS. Download the CA cert from the Aiven console
# (Service -> Overview -> "CA certificate") and point to it here:
DB_SSL_CA=./ca.pem

# On Vercel (no filesystem): base64-encode the cert and set this instead.
# Encode with: base64 -w0 ca.pem   (Linux/Mac)   or   certutil -encode ca.pem tmp && findstr /v CERTIFICATE tmp > ca_b64.txt  (Windows)
DB_SSL_CA_CONTENT=

# Comma-separated list of allowed front-end origins for CORS.
# In production set this to your Vercel frontend URL, e.g.:
# CORS_ORIGINS=https://dugout-app.vercel.app
CORS_ORIGINS=*
